@startuml
title 06. Supervisor A2A Request Sequence (Detailed Enterprise Architecture, 2026-04-30)

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20
autonumber

actor User
participant "supervisor_a2a_endpoint" as Controller
participant "supervisor_a2a_request_validator" as Validator
participant "supervisor_agent_service" as AgentService
participant "prompt_injection_guard" as Guard
participant "llm_planning_service" as Planner
participant "hitl_gate_service" as HitlGate
participant "task_queue_service" as TaskQueue #FFEBCF
participant "supervisor_execution_persistence_service" as PersistenceFacade
participant "execution_consistency_coordinator" as Consistency
participant "SnapshotVerificationQuery" as VerifyQuery
database "Redis (Queue/Stream/Store)" as Redis

box "Background Worker Tier" #F9F9F9
participant "worker.py" as Worker #EFE1FF
participant "supervisor_graph_execution_service" as GraphExecution
participant "LangGraph CompiledGraph" as Graph
participant "a2a_invocation_service" as Invoker
participant "supervisor_response_compose_service" as Composer
end box

participant "Downstream A2A Agents" as DownstreamAgents

== 1. Task Submission (API Tier) ==

User -> Controller : POST /a2a/supervisor\n(SendMessage, SendStreamingMessage)
activate Controller

Controller -> Validator : validate_request(params)
activate Validator
Validator --> Controller : valid
deactivate Validator

Controller -> AgentService : execute_task(session_id, message)
activate AgentService

AgentService -> Consistency : check_and_reserve_request(request_id)
note right: Redis SET NX (Idempotency Lock)
Consistency --> AgentService : (is_new, task_id)

AgentService -> HitlGate : evaluate_and_open_review(...)
activate HitlGate
HitlGate -> Guard : sanitize(message)
Guard --> HitlGate : clean_message

HitlGate -> Planner : plan(clean_message)
activate Planner
Planner -> Planner : _get_routing_decision()
Planner -> Planner : _evaluate_hitl_policy()
Planner --> HitlGate : frozen_plan, review_required
deactivate Planner

HitlGate -> PersistenceFacade : persist_review_open(...)
PersistenceFacade -> Consistency : createWaitingReviewWithSnapshot(...)
Consistency -> Redis : MULTI/EXEC (Atomic Save)
HitlGate --> AgentService : review_required, plan
deactivate HitlGate

alt review_required
    AgentService --> Controller : status: WAITING_REVIEW
else normal path / direct answer
    AgentService -> TaskQueue : enqueue_task(session_id, task_id, plan)
    activate TaskQueue
    TaskQueue -> Redis : LPUSH supervisor:task_queue
    TaskQueue --> AgentService : ack
    deactivate TaskQueue
    AgentService --> Controller : status: STREAMING + stream_endpoint
end

deactivate AgentService
Controller --> User : JSON-RPC Response (TaskView)
deactivate Controller

== 2. Background Execution (Worker Tier) ==

Worker -> TaskQueue : dequeue_task()
activate Worker
TaskQueue -> Redis : BRPOPLPUSH (Reliable Queue)
Redis --> TaskQueue : task_msg
TaskQueue --> Worker : task_msg {session_id, task_id, plan}

Worker -> GraphExecution : execute_plan(session_id, task_id, plan)
activate GraphExecution

GraphExecution -> Consistency : start_approved_resume()
note right: Atomic State Transition (CAS)
Consistency --> GraphExecution : success

GraphExecution -> Graph : invoke(state)
activate Graph

loop invoke / handoff cycle
    Graph -> Invoker : invoke(agent_key, method, args)
    activate Invoker
    Invoker -> DownstreamAgents : JSON-RPC Request
    DownstreamAgents --> Invoker : Result
    Invoker --> Graph : DownstreamCallResult
    deactivate Invoker
end

Graph --> GraphExecution : final_state
deactivate Graph

GraphExecution -> Composer : stream_compose(final_state)
activate Composer
Composer -> Redis : XADD supervisor:events (SSE)
Composer --> GraphExecution : completion
deactivate Composer

GraphExecution -> PersistenceFacade : persist_execution_completion(...)
PersistenceFacade -> Consistency : completeExecution(...)
Consistency -> Redis : MULTI/EXEC (Final State Update)

deactivate GraphExecution
deactivate Worker

== 3. Review Approval & Resume ==

User -> Controller : tasks/review/decide (APPROVE)
activate Controller
Controller -> AgentService : handle_review_decision(APPROVE)
activate AgentService

AgentService -> VerifyQuery : execute(task_id, params)
activate VerifyQuery
VerifyQuery -> VerifyQuery : check_hashes(request, plan)
VerifyQuery -> VerifyQuery : verify_resume_token()
VerifyQuery -> VerifyQuery : check_drift_policy()
VerifyQuery --> AgentService : verification_result (SUCCESS)
deactivate VerifyQuery

AgentService -> PersistenceFacade : start_approved_resume(...)
activate PersistenceFacade
PersistenceFacade -> Consistency : start_approved_resume (CAS)
Consistency -> Redis : WATCH task_version / MULTI / EXEC
Consistency --> PersistenceFacade : resume_data
PersistenceFacade --> AgentService : success
deactivate PersistenceFacade

AgentService -> TaskQueue : enqueue_task(frozen_plan)
note right: Execution handed back to Worker

AgentService --> Controller : approve_ack {initial_cursor}
deactivate AgentService
Controller --> User : JsonRpcResponse
deactivate Controller

@enduml
