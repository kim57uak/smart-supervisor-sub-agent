@startuml
title 06. Supervisor A2A Request Sequence (Python target architecture, 2026-04-25)

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20

actor User
participant "supervisor_a2a_endpoint" as Controller
participant "supervisor_a2a_request_validator" as Validator
participant "supervisor_agent_service" as AgentService
participant "supervisor_request_idempotency_service" as Idempotency
participant "supervisor_pre_hitl_a2ui_service" as PreHitlA2ui
participant "hitl_gate_service" as HitlGate
participant "supervisor_execution_service" as ExecutionService
participant "supervisor_review_application_service" as ReviewApp
participant "supervisor_execution_persistence_service" as PersistenceFacade
participant "execution_consistency_coordinator" as Consistency
participant "task_event_stream_service" as TaskEventStream
participant "supervisor_agent_orchestrator" as Orchestrator
participant "supervisor_graph_execution_service" as GraphExecution
participant "LangGraph CompiledGraph" as Graph
participant "a2a_invocation_service" as Invoker
participant "supervisor_response_compose_service" as Composer
participant "Downstream A2A Agents" as DownstreamAgents

User -> Controller : POST /a2a/supervisor\nJSON-RPC method:\nmessage/send or SendMessage\nmessage/stream or SendStreamingMessage
Controller -> Validator : precheck + validate params

alt unary send
  Controller -> AgentService : send(...)
  AgentService -> Idempotency : executeOnce(...)
  AgentService -> PreHitlA2ui : build(session_id, message, model)

  alt pre-HITL A2UI resolved
    AgentService -> PersistenceFacade : persistCompletion(...A2UI payload...)
    PersistenceFacade -> Consistency : completeExecution(...)
    AgentService --> Controller : JSON-RPC TaskView
  else normal execution path
    AgentService -> HitlGate : planAndAssessReview(...)
    alt HITL required
      AgentService -> HitlGate : openReview(...)
      HitlGate -> PersistenceFacade : openReview(...)
      PersistenceFacade -> Consistency : createWaitingReviewWithSnapshot(...)
      AgentService --> Controller : WAITING_REVIEW task
    else HITL passed
      AgentService -> ExecutionService : executeSync(...)
      ExecutionService -> PersistenceFacade : startExecution(...)
      ExecutionService -> Orchestrator : executeEvents(...)
      Orchestrator -> GraphExecution : execute(...)
      GraphExecution -> Graph : invoke(routingSelectedState)
      Graph -> Invoker : invoke(selected batch)
      Invoker -> DownstreamAgents : invoke\nmessage/send or SendMessage\nmessage/stream or SendStreamingMessage
      DownstreamAgents --> Invoker : downstream results
      Orchestrator -> Composer : streamComposeEvents(context)
      Composer --> Orchestrator : text / a2ui events
      ExecutionService -> PersistenceFacade : persistCompletion(...)
      PersistenceFacade -> Consistency : completeExecution(...)
      AgentService --> Controller : JSON-RPC TaskView
    end
  end
else stream request
  Controller -> AgentService : streamEvents(...)
  AgentService -> PreHitlA2ui : build(...)
  alt pre-HITL A2UI resolved
    AgentService --> Controller : progress + text + a2ui SSE
  else normal stream path
    AgentService -> HitlGate : planAndAssessReview(...)
    alt HITL required
      HitlGate -> PersistenceFacade : openReview(...)
      PersistenceFacade -> Consistency : createWaitingReviewWithSnapshot(...)
      AgentService --> Controller : waiting review progress stream
    else HITL passed
      AgentService -> ExecutionService : executeStreamEvents(...)
      ExecutionService -> PersistenceFacade : startExecution(...)
      ExecutionService -> Orchestrator : executeEvents(...)
      Orchestrator -> GraphExecution : execute(...)
      GraphExecution -> Graph : invoke(routingSelectedState)
      Graph -> Invoker : invoke(selected batch)
      Invoker -> DownstreamAgents : invoke\nmessage/send or SendMessage\nmessage/stream or SendStreamingMessage
      DownstreamAgents --> Invoker : downstream results
      Orchestrator -> Composer : streamComposeEvents(context)
      Composer --> Controller : SupervisorOutputEvent SSE
    end
  end
else review endpoints
  User -> Controller : tasks/review/decide\nminimum fields:\ntask_id, decision(APPROVE|CANCEL)
  Controller -> AgentService : getReview / decideReview / decideReviewStream
  AgentService -> ReviewApp : delegate review use case
  ReviewApp -> HitlGate : decideWithSnapshotVerification(...)
  alt approve verified and drift safe
    ReviewApp -> PersistenceFacade : startApprovedResume(...)
    PersistenceFacade -> Consistency : startApprovedResume(...)
    Consistency -> TaskEventStream : reserve durable initial_cursor
    ReviewApp -> ExecutionService : resumeApprovedSnapshot(...)
    ReviewApp --> Controller : approve ack(task_id, state_version,\nexecution_mode, resume_accepted,\nstream_resume_required, initial_cursor)
    note right of Controller
    STREAM resume rule:
    - server snapshot is the verification source of truth
    - approve ack is not the resumed runtime stream
    - do not continue original SSE connection
    - client re-subscribes by task_id + initial_cursor
    - runtime stream is delivered on task event stream
    - replayable events after approve are not lost
    end note
  else approve rejected or review reopened
    ReviewApp --> Controller : resume_rejected(reason_code)\nor reopen review response
  end
end

Controller --> User : JSON-RPC or SSE(chunk/a2ui/done)

note right of Controller
Compatibility
- legacy: message/send, message/stream,
  tasks/get, tasks/list, tasks/cancel
- current: SendMessage, SendStreamingMessage,
  GetTask, ListTasks, CancelTask
- validator/endpoint normalize both families
- endpoint is the final SSE adapter only; internal flow stays typed event based
end note

@enduml
