@startuml
!pragma layout smetana
title 03. Supervisor Host Agent Component Architecture (Vertical Optimized, 2026-04-30)

' Layout settings
top to bottom direction
skinparam shadowing false
skinparam componentStyle rectangle
skinparam nodesep 20
skinparam ranksep 30

' Layer 1: API & Security Entry
package "01. Entry & Security Layer" {
  [Supervisor API] as API
  [SupervisorA2aRequestValidator] as Validator
  [PromptInjectionGuard] as Guard
}

' Layer 2: Application Orchestration
package "02. Application Orchestration" {
  [SupervisorAgentService] as AgentService
  [HitlGateService] as HitlGate
  [FactGovernanceService] as FactGov
}

' Layer 3: Execution & Background Processing
package "03. Execution & Worker Layer" {
  [TaskQueueService] as TaskQueue #FFEBCF
  [WorkerExecutionService] as WorkerService #EFE1FF
  [SupervisorGraphExecutionService] as GraphService #DCEBFF
}

' Layer 4: Persistence & Read Models
package "04. Persistence & Read Layer" {
  [ExecutionConsistencyCoordinator] as Coordinator
  [SupervisorReadFacade] as ReadFacade
  [SnapshotVerificationQuery] as Verifier
}

' Layer 5: Technical Adapters
package "05. Technical Adapters" {
  [LlmPlanningService] as Planner
  [LlmComposeService] as Composer
  [LangGraphFactory] as GraphFactory
  [DefaultA2AInvocationService] as Invocation
}

' Infrastructure
database "Redis (Task/State/Stream)" as Redis #LightBlue

' Hidden links to force vertical stacking
API -[hidden]down-> AgentService
AgentService -[hidden]down-> TaskQueue
TaskQueue -[hidden]down-> Coordinator
Coordinator -[hidden]down-> Planner
Planner -[hidden]down-> Redis

' --- Main Flow ---

' 1. Request Flow
API -> Validator : validate
API -> AgentService : execute
HitlGate -> Guard : sanitize
AgentService -> HitlGate : process
HitlGate -> Planner : plan
HitlGate -> Coordinator : snapshot
HitlGate -> TaskQueue : enqueue

' 2. Worker Execution Flow
WorkerService -> TaskQueue : dequeue (Reliable)
WorkerService -> GraphService : run
GraphService -> GraphFactory : build
GraphService -> Invocation : call agent
GraphService -> FactGov : update facts
GraphService -> Composer : synthesize
GraphService -> Coordinator : update state

' 3. Review & Approval Flow
ReadFacade -> Verifier : check integrity
Verifier -> Coordinator : load snapshot

' 4. Infrastructure Connection
Coordinator -> Redis : MULTI/EXEC
TaskQueue -> Redis : LPUSH/BRPOP
Invocation -> Redis : CircuitBreaker
GraphService -> Redis : Stream SSE

note right of Guard
  Filters malicious 
  patterns & injections
end note

note right of Coordinator
  Ensures atomic state 
  transitions via Redis CAS
end note

@enduml
