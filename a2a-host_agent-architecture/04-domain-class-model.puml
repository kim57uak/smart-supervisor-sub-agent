@startuml
title 04. Supervisor Host Agent Domain Model (Python target architecture, 2026-04-25)

skinparam shadowing false
skinparam classAttributeIconSize 0

class SupervisorAgentRequest {
  +session_id: str
  +message: String
  +model: String
}

class SupervisorExecutionRequest {
  +session_id: str
  +message: String
  +model: String
}

class SupervisorPlanningContext {
  +task_id: str
  +session_id: str
  +user_message: str
  +model: String
  +history: List<String>
  +routing_plans: List<RoutingPlan>
  +results: List<DownstreamCallResult>
  +routingIndex: int
  +swarm_state_version: int
  +swarm_shared_facts: Map[str, object]
  +current_node: str
  +checkpoint_id: str
}

class RoutingPlan {
  +agent_key: str
  +method: String
  +reason: String
  +priority: int
  +arguments: Map<String, Object>
}

class DownstreamCallResult {
  +agent_key: str
  +task_id: str
  +status: String
  +payload: dict
  +error_code: String
  +error_message: String
  +handoff_requested: bool
  +next_agent_key: str
  +handoff_method: str
  +handoff_reason: str
  +handoff_arguments: Map[str, object]
}

class HitlPolicyResult {
  +required: boolean
  +policyId: String
  +reason: String
}

class HitlReviewTicket {
  +task_id: str
  +session_id: str
  +message: String
  +model: String
  +policy_id: str
  +policy_reason: str
  +status: HitlReviewStatus
  +decision_reason: str
  +decision_id: str
}

class ReviewedExecutionSnapshot {
  +task_id: str
  +session_id: str
  +request_id: str
  +trace_id: str
  +sanitized_input: Map[str, object]
  +request_hash: str
  +frozen_plan_hash: str
  +resume_token: str
  +state_version: int
  +created_at: datetime
  +expires_at: datetime
  +frozen_plan: FrozenExecutionPlan
}

class FrozenExecutionPlan {
  +task_id: str
  +session_id: str
  +request_id: str
  +trace_id: str
  +state_version: int
  +schema_version: int
  +canonicalization_version: int
  +execution_mode: ExecutionMode
  +resume_state: ResumeState
  +request_hash: str
  +frozen_plan_hash: str
  +created_at: datetime
  +expires_at: datetime
  +routing_queue: List<RoutingPlan>
  +planner_metadata: Map[str, object]
  +execution_constraints: ExecutionConstraintSet
}

class ExecutionConstraintSet {
  +maxConcurrency: int
  +streamAllowed: boolean
  +invokeTimeout: Duration
  +maxHandoffDepth: int
  +a2uiAllowed: boolean
}

class SwarmState {
  +task_id: str
  +session_id: str
  +state_version: int
  +updated_at: datetime
  +shared_facts: Map[str, object]
  +event_log: List[Map[str, object]]
}

class HandoffDirective {
  +from_agent_key: str
  +next_agent_key: str
  +method: String
  +reason: String
  +arguments: Map[str, object]
}

class HandoffValidationResult {
  +accepted: boolean
  +reason_code: String
  +directive: HandoffDirective
  +plan: RoutingPlan
  +hop_count: int
}

class InvocationPolicyContext {
  +plan: RoutingPlan
  +planning_context: SupervisorPlanningContext
}

class HitlPolicyContext {
  +session_id: str
  +message: String
  +model: String
}

class HandoffPolicyContext {
  +planning_context: SupervisorPlanningContext
  +batch_results: List<DownstreamCallResult>
}

class SupervisorOutputEvent {
  +type: SupervisorOutputEventType
  +content: String
}

class SupervisorGraphState {
  +SESSION_ID
  +TASK_ID
  +USER_MESSAGE
  +MODEL
  +HISTORY
  +CHECKPOINT_ID
  +CURRENT_NODE
  +ROUTING_PLANS
  +ROUTING_INDEX
  +CURRENT_PLAN
  +DOWNSTREAM_RESULTS
  +LAST_INVOKE_BATCH_RESULTS
  +HANDOFF_VALIDATIONS
  +HANDOFF_ENABLED
  +SWARM_SHARED_FACTS
  +SWARM_STATE_VERSION
}

class A2aTaskSnapshot {
  +task_id: str
  +session_id: str
  +status: A2aTaskStatus
  +request_message: str
  +response_payload: dict
  +error_code: str
  +error_message: str
}

enum A2aTaskStatus {
  SUBMITTED
  RUNNING
  WAITING_REVIEW
  COMPLETED
  FAILED
  CANCELED
}

interface SupervisorPlanningService {
  +plan(context): SupervisorPlanningDecision
}

interface HitlDecisionService {
  +openReview(...): HitlReviewTicket
  +getReview(...): Optional<HitlReviewTicket>
  +decide(...): Optional<HitlReviewTicket>
}

interface A2AInvocationService {
  +invoke(context): DownstreamCallResult
}

interface HandoffPolicyService {
  +evaluate(context): List<HandoffValidationResult>
}

interface SupervisorResponseComposeService {
  +stream_compose_events(context): AsyncIterator[SupervisorOutputEvent]
}

interface SupervisorSwarmCoordinator {
  +applyRoutingRule(...): List<RoutingPlan>
  +load_latest_by_session(session_id): Optional[SwarmState]
}

SupervisorAgentRequest --> SupervisorPlanningContext
SupervisorExecutionRequest --> SupervisorAgentRequest
SupervisorPlanningContext --> RoutingPlan
SupervisorPlanningContext --> DownstreamCallResult
SupervisorPlanningContext --> SwarmState
SupervisorPlanningContext --> SupervisorGraphState
DownstreamCallResult --> HandoffDirective
HandoffValidationResult --> HandoffDirective
HandoffValidationResult --> RoutingPlan
InvocationPolicyContext --> RoutingPlan
InvocationPolicyContext --> SupervisorPlanningContext
HandoffPolicyContext --> SupervisorPlanningContext
HandoffPolicyContext --> DownstreamCallResult
SupervisorPlanningService --> SupervisorPlanningDecision
HitlDecisionService --> HitlReviewTicket
HitlReviewTicket --> ReviewedExecutionSnapshot
ReviewedExecutionSnapshot --> FrozenExecutionPlan
FrozenExecutionPlan --> RoutingPlan
FrozenExecutionPlan --> ExecutionConstraintSet
SupervisorResponseComposeService --> SupervisorOutputEvent

note bottom of SupervisorPlanningContext
Current shared runtime state for:
- planning
- invoke/handoff
- compose
- swarm facts
- checkpoint recovery
- reviewed snapshot resume
end note

note bottom of FrozenExecutionPlan
Hash/verification rules:
- request_hash and frozen_plan_hash use deterministic canonical rules
- schemaVersion and canonicalizationVersion are part of the contract
- STREAM approve resumes by task event stream re-subscribe, not by continuing approve HTTP response
end note

@enduml
