@startuml
!pragma layout smetana
title 05. Supervisor Agent LangGraph Orchestration

skinparam shadowing false
skinparam linetype ortho
skinparam ActivityDiamondFontSize 12

start

:Build running context;
:Call HitlGateService for routing + review decision;
if (review required?) then (yes)
  :Freeze plan for review;
  :Create ReviewedExecutionSnapshot;
  :Set state to WAITING_REVIEW;
  stop
endif

:Mark RUNNING state via PersistenceFacade;
:Load snapshot + history/checkpoint/swarm;
:Invoke OrchestrationEngine (LangGraph);

partition "LangGraph Lifecycle" {
  :SELECT node;
  if (routing plan exists?) then (yes)
    :INVOKE node;
    :record invocation result;
    :HANDOFF_EVALUATE node;
    if (accepted handoff exists?) then (yes)
      :HANDOFF_APPLY node;
      :inject step into routing_queue;
    else (no)
      :keep original routing queue;
    endif
    :MERGE node;
    :Update Swarm Facts;
    if (more plans?) then (yes)
      :loop back to SELECT;
    endif
  else (no)
  endif
}

:COMPOSE phase entered (Outside Graph);
:<back:FFE7A8>Compose via LlmComposeService</back>;
note right
  Streaming tokens, 
  Reasoning, A2UI
end note

:Emit routing summary;
:Persist execution completion (final answer, swarm state);
:Emit DONE event;

stop

note right
Current graph contract
- nodes: select, invoke, handoff_evaluate, handoff_apply, merge
- Compose logic is outside the graph (handled by SupervisorGraphExecutionService)
- No HITL wait node inside graph
- select -> (invoke | end)
- Max iteration guard exists
- Progress/reasoning remain stream-only
end note
@enduml
