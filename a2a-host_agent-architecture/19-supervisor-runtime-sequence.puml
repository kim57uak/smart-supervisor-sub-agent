@startuml
title 19. Supervisor Runtime Sequence (Enterprise Decoupled & Idempotent)

skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam ParticipantPadding 20

actor User
participant "supervisor_a2a_endpoint" as Controller
participant "SupervisorAgentService" as AgentService
participant "ExecutionConsistencyCoordinator" as Consistency #DFF6EE
participant "HitlGateService" as HitlGate
participant "TaskQueueService" as TaskQueue #FFEBCF
participant "TaskEventStreamService" as TaskEventStream
database "Redis (Queue/Stream/Store)" as Redis

box "Background Worker Tier" #F9F9F9
participant "worker.py" as Worker #EFE1FF
participant "SupervisorGraphExecutionService" as GraphExecution
participant "LangGraph CompiledGraph" as Graph
participant "DefaultA2AInvocationService" as Invoker
participant "LlmSupervisorResponseComposeService" as Composer
end box

User -> Controller : SendMessage / SendStreamingMessage
Controller -> AgentService : execute_task(session_id, message)

== 1. Idempotency & Admission ==
AgentService -> Consistency : check_and_reserve_request(request_id)
Consistency -> Redis : SET request_lock:{id} NX EX 3600
Redis --> Consistency : OK / Existing task_id

alt duplicate request
  Consistency --> AgentService : Existing task_id
  AgentService --> Controller : Existing task view (Polling endpoint)
else new request
  Consistency --> AgentService : Success (New task_id)
  
  == 2. Planning & HITL Evaluation ==
  AgentService -> HitlGate : evaluate_and_open_review(...)
  HitlGate -> HitlGate : Sanitize input (PromptInjectionGuard)
  HitlGate -> HitlGate : Planning (PlanningService) + Hash calculation
  
  alt no review needed
    HitlGate --> AgentService : review_required: false
    AgentService -> TaskQueue : enqueue_task(plan)
    TaskQueue -> Redis : LPUSH supervisor:task_queue
    AgentService --> Controller : status: STREAMING, stream_endpoint: /stream
  else review required
    HitlGate -> Redis : persist_review_open (with snapshot)
    HitlGate --> AgentService : review_required: true
    AgentService --> Controller : status: WAITING_REVIEW, review_id: {id}
  end
end

== 3. Background Execution (Worker) ==

Worker -> Redis : BRPOPLPUSH supervisor:task_queue
Redis --> Worker : task_msg
Worker -> GraphExecution : execute_plan(plan)
activate GraphExecution

GraphExecution -> Redis : load_swarm_state(session_id)
GraphExecution -> Graph : invoke(initial_state)

loop Graph Nodes (select -> invoke -> handoff -> merge)
  Graph -> Invoker : invoke downstream (with Circuit Breaker)
  Invoker --> Graph : result
  Graph -> TaskEventStream : publish_chunk / publish_progress
  TaskEventStream -> Redis : XADD supervisor:events
end

GraphExecution -> Composer : stream_compose(results)
loop Stream LLM Response
    Composer -> TaskEventStream : publish_chunk / publish_reasoning
    TaskEventStream -> Redis : XADD supervisor:events
end

GraphExecution -> Consistency : complete_execution(task_id, result)
Consistency -> Redis : MULTI/EXEC (Atomic Terminal State)
GraphExecution -> TaskEventStream : publish_done
deactivate GraphExecution

== 4. Observation (SSE Subscription) ==

User -> Controller : POST /stream (TaskEvents)
Controller -> TaskEventStream : subscribe(task_id, cursor)
TaskEventStream -> Redis : XREAD (tail + live events)
Redis --> User : event: chunk / reasoning / a2ui / done

@enduml
