@startuml
!pragma layout smetana
title 07. Supervisor Agent Streaming Response Sequence (Decoupled Enterprise Architecture)

skinparam shadowing false
skinparam sequenceMessageAlign center
autonumber

actor User

box "API Tier" #E8F8F5
participant "supervisor_a2a_endpoint" as Controller
participant "SupervisorA2aRequestValidator" as Validator
participant "SupervisorAgentService" as AgentService
participant "TaskEventStreamService" as EventService
end box

box "Message Broker (Redis)" #FDF2E9
database "supervisor:task_queue" as TaskQueue
database "supervisor:events" as EventStream
end box

box "Worker Tier" #F9E79F
participant "worker.py" as Worker
participant "SupervisorGraphExecutionService" as GraphExecution
participant "SupervisorProgressPublisher" as Publisher
participant "LlmSupervisorResponseComposeService" as Composer
participant "DefaultSupervisorLlmRuntime" as Runtime
end box

== 1. Task Submission (Unary) ==
User -> Controller : POST /a2a/supervisor\nJSON-RPC method: message/send
Controller -> Validator : validate_request(params)
Validator --> Controller : valid
Controller -> AgentService : execute_task(session_id, message)

AgentService -> TaskQueue : LPUSH (Enqueue Plan)
AgentService --> Controller : status: STREAMING\nstream_endpoint: /stream
Controller --> User : JSON-RPC Response (TaskView)

== 2. Stream Subscription (SSE) ==
User -> Controller : POST /a2a/supervisor/stream\nAccept: text/event-stream\nJSON-RPC method: tasks/events
Controller -> EventService : subscribe(session_id, task_id, cursor)

loop Event Polling / Replay (XREAD block)
    EventService -> EventStream : XREAD
    EventStream --> EventService : event payload
    EventService --> Controller : yield SupervisorTaskEvent
    Controller --> User : SSE data: {event_type, payload}
end

== 3. Background Execution & Event Publishing ==
Worker -> TaskQueue : BRPOPLPUSH
TaskQueue --> Worker : task_msg
Worker -> GraphExecution : execute_plan(session_id, task_id, plan)

loop Graph Execution
    GraphExecution -> Publisher : publish_progress(...)
    Publisher -> EventStream : XADD
    GraphExecution -> Publisher : publish_chunk(agent_key, payload)
    Publisher -> EventStream : XADD
end

GraphExecution -> Composer : stream_compose(results, context)
Composer -> Runtime : astream(prompt)
Runtime --> Composer : AsyncIterator[chunk]

loop Stream LLM Response
    Composer --> GraphExecution : yield (event_type, token)
    GraphExecution -> Publisher : publish_event(type, token)
    Publisher -> EventStream : XADD
end

GraphExecution -> Publisher : publish_done(final_result)
Publisher -> EventStream : XADD

note right of Controller
Current SSE framing for Client
- event_type: reasoning
- event_type: chunk
- event_type: a2ui
- event_type: error
- event_type: done
end note
@enduml
