@startuml
!pragma layout smetana
title 01. Agentic AI System Context (Python target implementation baseline)

skinparam shadowing false
skinparam componentStyle rectangle

actor User
actor "Supervisor Agent" as Supervisor

rectangle "Client Channels" {
  [Web UI] as WebUi
  [REST Client] as RestClient
  [A2A Peer] as A2APeer
}

rectangle "mcp-orchestrator" {
  [Domain Endpoints\n/weather, /supply-cost,\n/reservation, /sale-product] as domain_endpoints
  [A2A Endpoints\n/a2a/{scope}] as a2a_endpoints
  [agent_card_endpoint] as agent_card_endpoint
  [agent_authorization_service] as agent_authorization_service
  [session_authorization_store] as session_authorization_store
  [ai_chat_service facade] as ai_chat_service
  [agent_orchestrator] as agent_orchestrator
  [LangGraph compiled graph] as state_graph
  [planning_service] as planning_service
  [tool_execution_service] as tool_execution_service
  [response_compose_service] as response_compose_service
  [a2a_lifecycle_service] as a2a_lifecycle_service
  [a2a_response_mapper] as a2a_response_mapper
  [conversation_store] as conversation_store
  [graph_checkpoint_store] as graph_checkpoint_store
  [a2a_task_store] as a2a_task_store
  [redis_store_facade] as redis_store_facade
  [agent_llm_runtime] as agent_llm_runtime
  [mcp_tool_registry] as mcp_tool_registry
  [mcp_client_session_manager] as mcp_client_session_manager
  [mcp_transport_factory] as mcp_transport_factory
}

database "Redis" as Redis

cloud "LLM Providers" {
  [OpenAI] as OpenAI
  [Google Gemini] as Gemini
}

node "MCP Servers" {
  [Weather MCP] as WeatherMcp
  [Supply Cost MCP] as SupplyCostMcp
  [Reservation MCP] as ReservationMcp
  [Sale Product MCP] as SaleProductMcp
}

artifact "settings/agent.yml" as agent_yml
artifact "settings/mcp.yml" as mcp_yml
artifact "settings/a2a.yml" as a2a_yml

User --> WebUi
User --> RestClient
Supervisor --> A2APeer

WebUi --> domain_endpoints
RestClient --> domain_endpoints
A2APeer --> a2a_endpoints
A2APeer --> agent_card_endpoint

domain_endpoints --> agent_authorization_service
a2a_endpoints --> agent_authorization_service
agent_authorization_service --> session_authorization_store
domain_endpoints --> ai_chat_service
a2a_endpoints --> ai_chat_service
a2a_endpoints --> a2a_lifecycle_service
a2a_endpoints --> a2a_response_mapper
agent_card_endpoint --> a2a_response_mapper

ai_chat_service --> agent_orchestrator
agent_orchestrator --> state_graph
state_graph --> planning_service
state_graph --> tool_execution_service
agent_orchestrator --> conversation_store
agent_orchestrator --> graph_checkpoint_store
agent_orchestrator --> a2a_lifecycle_service
agent_orchestrator --> response_compose_service
a2a_lifecycle_service --> a2a_task_store
conversation_store --> redis_store_facade
graph_checkpoint_store --> redis_store_facade
a2a_task_store --> redis_store_facade
redis_store_facade --> Redis

planning_service --> agent_llm_runtime
response_compose_service --> agent_llm_runtime
tool_execution_service --> mcp_tool_registry
mcp_tool_registry --> mcp_client_session_manager
mcp_client_session_manager --> mcp_transport_factory

agent_llm_runtime --> OpenAI
agent_llm_runtime --> Gemini
mcp_transport_factory --> WeatherMcp
mcp_transport_factory --> SupplyCostMcp
mcp_transport_factory --> ReservationMcp
mcp_transport_factory --> SaleProductMcp

agent_yml --> ai_chat_service
agent_yml --> agent_orchestrator
agent_yml --> agent_llm_runtime
agent_yml --> mcp_yml
agent_yml --> a2a_yml
mcp_yml --> mcp_tool_registry
a2a_yml --> a2a_endpoints
a2a_yml --> agent_card_endpoint

@enduml
