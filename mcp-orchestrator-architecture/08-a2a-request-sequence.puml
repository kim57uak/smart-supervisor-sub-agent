@startuml
title 08. A2A Request Sequence

skinparam shadowing false

actor Supervisor
participant "scope_a2a_endpoint" as Endpoint
participant "request_idempotency_policy" as Idempotency
participant "a2a_lifecycle_service" as Lifecycle
participant "ai_chat_service" as ChatService
participant "agent_orchestrator" as Orchestrator
participant "LangGraph graph" as Graph
participant "tool_catalog_service" as ToolCatalog
participant "llm_planning_service" as Planner
participant "mcp_tool_execution_service" as Executor
participant "response_compose_service" as Composer

Supervisor -> Endpoint : POST /a2a/sale-product\nSendMessage or message/send\ntrace_id + request_id + session_id
Endpoint -> Idempotency : execute(session_id + scope + method + request_id + request_hash)
alt cached response
  Idempotency --> Endpoint : cached JsonRpcResponse
  Endpoint --> Supervisor : JSON-RPC response
else execute
  Endpoint -> Lifecycle : create_and_mark_running(...)
  Idempotency -> ChatService : execute_agent_for_a2a(request + a2a_context)
  ChatService -> Orchestrator : execute_to_result(request)
  Orchestrator -> Graph : invoke(initial_state)
  Graph -> ToolCatalog : load_scoped_tools(scope)
  Graph -> Planner : plan(context)
  Graph -> Executor : execute(tool_plan)
  Graph --> Orchestrator : finalized context
  Orchestrator -> Composer : compose(context)
  Orchestrator --> ChatService : AgentExecutionResult
  ChatService --> Idempotency : final context + compose chunks
  Idempotency --> Endpoint : JsonRpcResponse + cache save
  Endpoint --> Supervisor : channels.raw-data + channels.compose-result
end

@enduml
