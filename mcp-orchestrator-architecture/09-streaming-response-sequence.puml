@startuml
!pragma layout smetana
title 09. Streaming Response Sequence

skinparam shadowing false

actor User
participant "agent_endpoint" as Endpoint
participant "request_idempotency_policy" as Idempotency
participant "ai_chat_service" as ChatService
participant "agent_orchestrator" as Orchestrator
participant "LangGraph CompiledGraph" as Graph
participant "tool_catalog_service" as ToolCatalog
participant "llm_planning_service" as Planner
participant "mcp_tool_execution_service" as Executor
participant "response_compose_service" as Composer
participant "agent_llm_runtime" as Runtime

User -> Endpoint : POST /api/*/chat or /chunks
alt idempotency required for side-effect or long-running request
  Endpoint -> Idempotency : check cached response / acquire in-flight key
  alt completed response cached
    Idempotency --> Endpoint : cached final response
    Endpoint --> User : JSON-RPC response or final chunk payload
  else proceed with streaming execution
    Idempotency -> ChatService : stream_agent_chat(request)
    ChatService -> Orchestrator : execute(request)
    Orchestrator -> Graph : invoke(initial_state)
    Graph -> ToolCatalog : load_scoped_tools(scope)
    ToolCatalog --> Graph : allowlisted tool catalog
    Graph -> Planner : plan(context)
    Graph -> Executor : execute(tool_plan)
    Graph --> Orchestrator : finalized context
    Orchestrator -> Composer : stream_compose(context)
    Composer -[#FF6B6B]> Runtime : stream(prompt, model)
    loop token/chunk
      Runtime -[#FF6B6B]--> Composer : AiChatChunk
      Composer --> Orchestrator : AiChatChunk
      Orchestrator --> ChatService : AiChatChunk
      ChatService --> Idempotency : stream
      Idempotency --> Endpoint : stream
      Endpoint --> User : text/plain or ndjson or JSON-RPC chunk
    end
  end
else idempotency optional read-only request
  Endpoint -> ChatService : stream_agent_chat(request)
  ChatService -> Orchestrator : execute(request)
  Orchestrator -> Graph : invoke(initial_state)
  Graph -> ToolCatalog : load_scoped_tools(scope)
  ToolCatalog --> Graph : allowlisted tool catalog
  Graph -> Planner : plan(context)
  Graph -> Executor : execute(tool_plan)
  Graph --> Orchestrator : finalized context
  Orchestrator -> Composer : stream_compose(context)
  Composer -[#FF6B6B]> Runtime : stream(prompt, model)
  loop token/chunk
    Runtime -[#FF6B6B]--> Composer : AiChatChunk
    Composer --> Orchestrator : AiChatChunk
    Orchestrator --> ChatService : AiChatChunk
    ChatService --> Endpoint : stream
    Endpoint --> User : text/plain or ndjson or JSON-RPC chunk
  end
end

@enduml
