@startuml
title 07. Reservation Query Sequence

skinparam shadowing false

actor User
participant "reservation_endpoint" as Endpoint
participant "agent_request_factory" as RequestFactory
participant "ai_chat_service" as ChatService
participant "agent_orchestrator" as Orchestrator
participant "LangGraph graph" as Graph
participant "llm_planning_service" as Planner
participant "mcp_tool_execution_service" as Executor
participant "response_compose_service" as Composer

User -> Endpoint : POST /api/reservation/chat
Endpoint -> RequestFactory : build request + history + scope
RequestFactory --> Endpoint : AgentChatRequest
Endpoint -> ChatService : stream_agent_chat(request)
ChatService -> Orchestrator : execute(request)
Orchestrator -> Graph : invoke(initial_state)
Graph -> Planner : plan(context)
Graph -> Executor : execute(tool_plan)
Graph --> Orchestrator : finalized context
Orchestrator -> Composer : stream_compose(context)
Composer --> Endpoint : text stream
Endpoint --> User : text/plain stream

@enduml
