@startuml
title 12. Deployment Runtime

skinparam shadowing false

node "FastAPI Runtime" {
  [agent endpoints]
  [a2a endpoints]
  [agent orchestrator]
  [agent llm runtime]
}

database "Redis" as redis
cloud "LLM Providers" as llm
node "MCP Servers" as mcp

[agent orchestrator] --> redis
[agent llm runtime] --> llm
[agent orchestrator] --> mcp

note bottom
- include session_id in every key
- propagate trace_id + request_id + session_id
end note

@enduml
