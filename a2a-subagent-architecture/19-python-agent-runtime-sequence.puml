@startuml
title 19. Sub-Agent Runtime Sequence (2026-04-30)

skinparam shadowing false
autonumber

actor Supervisor
participant "A2A Endpoint" as API
participant "Agent Executor" as Executor
participant "Background Worker" as Worker
participant "LangGraph" as Graph
participant "LLM Adapter" as LLM
participant "MCP Infrastructure" as MCP
database "Redis" as Redis
participant "MCP Server" as MCPServer

== 1. Task Reception (Producer) ==
Supervisor -> API : POST /a2a/product (JsonRpc)
API -> Executor : enqueue(session_id, message)
Executor -> Redis : LPUSH subagent:queue
API -->> Supervisor : 202 Accepted (task_id)

== 2. Task Execution (Consumer) ==
Worker -> Redis : BRPOP subagent:queue
Worker -> Executor : execute(task_id)
Executor -> Graph : ainvoke()

Graph -> LLM : plan(message, tools)
LLM -->> Graph : ToolPlan (name, arguments)

loop For each tool in plan
    Graph -> MCP : call(tool_name, arguments)
    MCP -> MCP : get_session(server)
    alt No session
        MCP -> MCPServer : call("initialize")
        MCPServer -->> MCP : Session ID
    end
    MCP -> MCPServer : call(tool_name, arguments)
    MCPServer -->> MCP : Tool Result (SSE/JSON)
    MCP -->> Graph : Result
end

Graph -> LLM : compose(history, results)
LLM -->> Graph : Final Answer

Graph -> Executor : complete
Executor -> Redis : SET task:result
Executor -> Redis : XADD stream:events (Final)

@enduml
