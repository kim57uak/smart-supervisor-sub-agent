@startuml
title 08. Sub-Agent A2A Request Sequence (Enterprise Decoupled)

skinparam shadowing false
skinparam sequenceMessageAlign center

actor "Client UI" as UI
participant "Supervisor" as Supervisor
participant "discovery.router" as API
participant "AgentChatUseCase" as UseCase
participant "AgentPersistence" as Persistence
participant "Redis (Queue)" as Queue
participant "WorkerExecutionService" as Worker
participant "AgentExecutor" as Executor
participant "OrchestrationEngine" as Engine

UI -> Supervisor: message/send (session_id, message)
note right: session_id is UI-generated (localStorage)

Supervisor -> API : POST /a2a/subagent (SendMessage)
note right: session_id must be propagated in params
activate API

API -> UseCase : handle_chat_request(session_id, message)
activate UseCase

UseCase -> Persistence : check_and_reserve_idempotency(request_id)
Persistence --> UseCase : Success (New Task)

UseCase -> Persistence : save_task(initial_state)
UseCase -> Queue : LPUSH (task_data)
UseCase --> API : status: ACCEPTED, task_id: {id}

API --> Supervisor : JSON-RPC Response (Accepted)
deactivate API
deactivate UseCase

Supervisor --> UI: JSON-RPC Response (Accepted)

== Background Execution ==

Worker -> Queue : BRPOP
Queue --> Worker : task_data

Worker -> Executor : execute(session_id, task_id, message)
activate Executor

Executor -> Persistence : update_status(RUNNING)
Executor -> Engine : execute(initial_state)
activate Engine

Engine -> Engine : LangGraph Workflow (Plan -> Exec -> Compose)
Engine --> Executor : final_state
deactivate Engine

Executor -> Persistence : complete_task(result)
Executor -> Persistence : save_message(ASSISTANT, answer)
deactivate Executor

@enduml
