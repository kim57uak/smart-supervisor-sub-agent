@startuml
!pragma layout smetana
title 03. Sub-Agent Component Architecture (2026-04-30)

skinparam shadowing false
skinparam componentStyle rectangle

package "API Layer" {
  [A2A Handler] as A2A
  [Chat API] as Chat
  [Discovery API] as Discovery
}

package "Application Layer" {
  [Agent Executor] as Executor
  [Chat Usecase] as Usecase
  [Background Worker] as Worker
  [Progress Publisher] as Publisher
}

package "Adapters" {
  [MCP Infrastructure] as MCP
  [LLM Adapter] as LLM
  [LangGraph Factory] as GraphFactory
  [Redis Store] as Store
}

database "Redis" as Redis
package "MCP Servers" as MCPServers

A2A -> Executor : Enqueue Task
Chat -> Usecase
Usecase -> Executor
Worker -> Redis : Poll Task
Worker -> Executor : Execute
Executor -> GraphFactory
GraphFactory -> LLM : Plan / Compose
GraphFactory -> MCP : Call Tool
MCP -> MCPServers : JSON-RPC over SSE/HTTP
Executor -> Publisher : Stream Events
Publisher -> Redis : XADD
Executor -> Store : Persist State
Store -> Redis
@enduml
