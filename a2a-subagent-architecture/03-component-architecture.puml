@startuml
!pragma layout smetana
title 03. Sub-Agent Component Architecture (2026-05-01)

skinparam shadowing false
skinparam componentStyle rectangle

package "API Layer" {
  [Discovery API] as Discovery
  [Chat API] as Chat
}

package "Application Layer" {
  [AgentChatUseCase] as Usecase
  [AgentExecutor] as Executor
  [WorkerExecutionService] as Worker
  [AgentProgressPublisher] as Publisher
}

package "Adapters & Engine" {
  [McpToolRegistry] as Registry
  [McpToolExecutor] as McpExec
  [LlmPlanningService] as Planner
  [LlmResponseComposeService] as Composer
  [OrchestrationEngine (LangGraph/Burr)] as Engine
  [RedisStores] as Store
}

database "Redis" as Redis
node "MCP Servers" as MCPServers

Discovery -> Usecase : Handle A2A
Chat -> Usecase : Handle Chat
Usecase -> Store : Save Initial State
Usecase -> Redis : LPUSH (Task Queue)

Worker -> Redis : BRPOP
Worker -> Executor : Execute
Executor -> Engine : Run Workflow
Engine -> Planner : Plan Tools
Engine -> McpExec : Execute Tool
McpExec -> Registry : Get Schema
McpExec -> MCPServers : JSON-RPC
Engine -> Composer : Stream Response

Executor -> Publisher : Publish Progress
Publisher -> Redis : XADD (Event Stream)
Executor -> Store : Persist State
Store -> Redis : SAVE
@enduml
