@startuml
!pragma layout smetana
title 02. Sub-Agent Package Policy (Python runtime: src/app)

skinparam shadowing false
skinparam packageStyle rectangle

package "src/app" {
  package "api" {
    package "a2a" {
        class discovery
    }
    package "agent" {
        class chat
    }
    package "support" {
        class stream
        class a2a_handler
        class agent_request_factory
    }
  }

  package "application" {
    package "execution" {
      class executor
      class chat_usecase
      class worker
      class agent_progress_publisher
    }
    package "persistence" {
      class agent_persistence
      class execution_consistency_coordinator
    }
    package "read" {
      class agent_read_facade
    }
  }

  package "adapters" {
    package "mcp" {
      class mcp_infrastructure
      class mcp_adapters
      class mcp_tool_registry
    }
    package "llm" {
      class llm_adapters
    }
    package "orchestration" {
      class langgraph_factory
    }
    package "store" {
      class redis_store
    }
  }

  package "core" {
    class config
    class dependencies
  }

  package "domain" {
    class models
    class enums
    class exceptions
  }

  package "infrastructure" {
    class redis_client
    class llm_runtime
  }

  package "ports" {
    class interfaces
  }
}

note bottom
Rules
- API Layer는 A2A(JSON-RPC) 및 User Chat 엔드포인트를 제공한다.
- Application Layer는 AgentExecutor를 통해 실제 로직을 오케스트레이션한다.
- MCP Adapter는 Spring AI MCP 서버와의 연동(Handshake, Transport)을 담당한다.
- 모든 실행 상태는 Redis를 통해 영속화 및 실시간 스트리밍(SSE)된다.
end note
@enduml
